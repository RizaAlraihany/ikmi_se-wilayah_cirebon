generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum ContentPlanStatus {
  PLANNED
  IN_PROGRESS
  READY
  PUBLISHED
}

enum RegStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  UNREAD
  PROCESSED
  RESOLVED
  REJECTED
}

enum FinanceStatus {
  PENDING
  APPROVED_TIER1
  COMPLETED
  REJECTED
}

enum LPJStatus {
  SUBMITTED
  VERIFIED_DEPARTMENT
  VERIFIED_BPH
  REJECTED
}

enum ProgramStatus {
  PLANNED
  ONGOING
  COMPLETED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  REGISTRATION
  FINANCE
  POST
  COMPLAINT
  LPJ
  SYSTEM
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  PUBLISH
  ARCHIVE
  VERIFY
}

enum LetterType {
  IN
  OUT
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  roleId       String    @map("role_id")
  departmentId String?   @map("department_id")
  positionId   String?   @map("position_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  role          Role           @relation(fields: [roleId], references: [id])
  department    Department?    @relation(fields: [departmentId], references: [id])
  position      Position?      @relation(fields: [positionId], references: [id])
  posts         Post[]
  auditLogs     AuditLog[]
  notifications Notification[]
  contentPlans  ContentPlan[]
  mediaAssets   MediaAsset[]

  @@index([roleId])
  @@index([departmentId])
  @@index([positionId])
  @@map("users")
}

model Role {
  id          String  @id @default(cuid())
  name        String
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id     String @id @default(cuid())
  name   String
  module String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id   String @id @default(cuid())
  name String
  code String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  users           User[]
  programs        Program[]
  financeRequests FinanceRequest[]
  positions       Position[]

  @@map("departments")
}

model Position {
  id           String  @id @default(cuid())
  name         String
  departmentId String? @map("department_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  department Department? @relation(fields: [departmentId], references: [id])
  users      User[]

  @@index([departmentId])
  @@map("positions")
}

model Category {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  description String @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  posts Post[]

  @@map("categories")
}

model Post {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  content        String     @db.Text
  excerpt        String?    @db.Text
  thumbnailUrl   String     @map("thumbnail_url")
  seoTitle       String?    @map("seo_title")
  seoDescription String?    @map("seo_description") @db.Text
  seoKeywords    String?    @map("seo_keywords") @db.Text
  status         PostStatus
  authorId       String     @map("author_id")
  categoryId     String     @map("category_id")
  reviewedBy     String?    @map("reviewed_by")
  reviewedAt     DateTime?  @map("reviewed_at")
  publishedBy    String?    @map("published_by")
  publishedAt    DateTime?  @map("published_at")
  archivedAt     DateTime?  @map("archived_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  author   User     @relation(fields: [authorId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@map("posts")
}

model ContentPlan {
  id          String            @id @default(cuid())
  title       String
  platform    String
  publishDate DateTime          @map("publish_date")
  status      ContentPlanStatus
  authorId    String            @map("author_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  author User @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([status])
  @@map("content_plans")
}

model MediaAsset {
  id         String @id @default(cuid())
  publicId   String @unique @map("public_id")
  url        String
  secureUrl  String @map("secure_url")
  filename   String
  mimeType   String @map("mime_type")
  size       Int
  width      Int?
  height     Int?
  folder     String
  uploadedBy String @map("uploaded_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  uploader User @relation(fields: [uploadedBy], references: [id])

  @@index([uploadedBy])
  @@index([mimeType])
  @@index([createdAt])
  @@map("media_assets")
}

model Program {
  id           String        @id @default(cuid())
  name         String
  departmentId String        @map("department_id")
  budgetPlan   Decimal       @map("budget_plan")
  description  String        @db.Text
  status       ProgramStatus

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  department Department @relation(fields: [departmentId], references: [id])
  events     Event[]
  activities Activity[]

  @@index([departmentId])
  @@index([status])
  @@map("programs")
}

model Activity {
  id          String        @id @default(cuid())
  programId   String        @map("program_id")
  name        String
  description String?       @db.Text
  status      ProgramStatus

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  program Program @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([status])
  @@map("activities")
}

model Event {
  id          String      @id @default(cuid())
  programId   String      @map("program_id")
  title       String
  description String      @db.Text
  location    String
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  status      EventStatus

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  program Program @relation(fields: [programId], references: [id])
  report  Report?

  @@index([programId])
  @@index([startDate])
  @@index([status])
  @@map("events")
}

model Report {
  id          String    @id @default(cuid())
  eventId     String    @unique @map("event_id")
  documentUrl String    @map("document_url")
  status      LPJStatus
  submittedBy String    @map("submitted_by")
  verifiedBy  String?   @map("verified_by")
  verifiedAt  DateTime? @map("verified_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  event Event @relation(fields: [eventId], references: [id])

  @@index([status])
  @@map("reports")
}

model Registration {
  id       String    @id @default(cuid())
  fullName String    @map("full_name")
  campus   String
  major    String
  semester String
  address  String    @db.Text
  whatsapp String
  reasons  String    @db.Text
  status   RegStatus

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([status])
  @@index([campus])
  @@map("registrations")
}

model Complaint {
  id         String          @id @default(cuid())
  senderName String          @map("sender_name")
  campus     String
  category   String
  message    String          @db.Text
  status     ComplaintStatus
  assignedTo String?         @map("assigned_to")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([status])
  @@index([assignedTo])
  @@map("complaints")
}

model Letter {
  id           String     @id @default(cuid())
  letterNumber String     @unique @map("letter_number")
  type         LetterType
  subject      String
  fileUrl      String     @map("file_url")
  date         DateTime

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([type])
  @@map("letters")
}

model FinanceRequest {
  id           String        @id @default(cuid())
  amount       Decimal
  description  String
  proofUrl     String        @map("proof_url")
  status       FinanceStatus
  departmentId String        @map("department_id")
  approvedBy1  String?       @map("approved_by_1")
  approvedBy2  String?       @map("approved_by_2")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  department Department @relation(fields: [departmentId], references: [id])

  @@index([status])
  @@index([departmentId])
  @@map("finance_requests")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  actionUrl String           @map("action_url")
  readAt    DateTime?        @map("read_at")
  userId    String           @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("notifications")
}

model AuditLog {
  id       String      @id @default(cuid())
  action   AuditAction
  entity   String
  entityId String      @map("entity_id")
  oldData  String?     @map("old_data") @db.Text
  newData  String?     @map("new_data") @db.Text
  userId   String      @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}

model WebConfig {
  id        String @id @default(cuid())
  key       String @unique
  valueJson String @map("value_json") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@map("web_configs")
}
