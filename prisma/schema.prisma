generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum RegStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  UNREAD
  PROCESSED
  RESOLVED
  REJECTED
}

enum FinanceStatus {
  PENDING
  APPROVED_TIER1
  COMPLETED
  REJECTED
}

enum LPJStatus {
  SUBMITTED
  VERIFIED_DEPARTMENT
  VERIFIED_BPH
  REJECTED
}

enum ProgramStatus {
  PLANNED
  ONGOING
  COMPLETED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  REGISTRATION
  FINANCE
  POST
  COMPLAINT
  LPJ
  SYSTEM
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  PUBLISH
  VERIFY
}

enum LetterType {
  IN
  OUT
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  roleId       String    @map("role_id")
  departmentId String    @map("department_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role         Role            @relation(fields: [roleId], references: [id])
  department   Department      @relation(fields: [departmentId], references: [id])
  posts        Post[]
  auditLogs    AuditLog[]
  notifications Notification[]

  @@index([roleId])
  @@index([departmentId])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id     String           @id @default(cuid())
  name   String
  module String
  roles  RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id   String @id @default(cuid())
  name String
  code String

  users           User[]
  programs        Program[]
  financeRequests FinanceRequest[]

  @@map("departments")
}

model Category {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String @db.Text

  posts Post[]

  @@map("categories")
}

model Post {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  content      String     @db.Text
  thumbnailUrl String     @map("thumbnail_url")
  status       PostStatus
  authorId     String     @map("author_id")
  categoryId   String     @map("category_id")
  publishedAt  DateTime?  @map("published_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  author   User     @relation(fields: [authorId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@map("posts")
}

model Program {
  id           String        @id @default(cuid())
  name         String
  departmentId String        @map("department_id")
  budgetPlan   Decimal       @map("budget_plan")
  description  String        @db.Text
  status       ProgramStatus
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  department Department @relation(fields: [departmentId], references: [id])
  events     Event[]

  @@index([departmentId])
  @@index([status])
  @@map("programs")
}

model Event {
  id          String      @id @default(cuid())
  programId   String      @map("program_id")
  title       String
  description String      @db.Text
  location    String
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  status      EventStatus
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  program Program @relation(fields: [programId], references: [id])
  report  Report?

  @@index([programId])
  @@index([startDate])
  @@index([status])
  @@map("events")
}

model Report {
  id          String    @id @default(cuid())
  eventId     String    @unique @map("event_id")
  documentUrl String    @map("document_url")
  status      LPJStatus
  submittedBy String    @map("submitted_by")
  verifiedBy  String?   @map("verified_by")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([status])
  @@map("reports")
}

model Registration {
  id        String    @id @default(cuid())
  fullName  String    @map("full_name")
  campus    String
  major     String
  semester  String
  address   String    @db.Text
  whatsapp  String
  reasons   String    @db.Text
  status    RegStatus
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([campus])
  @@map("registrations")
}

model Complaint {
  id         String          @id @default(cuid())
  senderName String          @map("sender_name")
  campus     String
  category   String
  message    String          @db.Text
  status     ComplaintStatus
  assignedTo String?         @map("assigned_to")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  deletedAt  DateTime?       @map("deleted_at")

  @@index([status])
  @@index([assignedTo])
  @@map("complaints")
}

model Letter {
  id           String     @id @default(cuid())
  letterNumber String     @unique @map("letter_number")
  type         LetterType
  subject      String
  fileUrl      String     @map("file_url")
  date         DateTime
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  @@index([type])
  @@map("letters")
}

model FinanceRequest {
  id           String        @id @default(cuid())
  amount       Decimal
  description  String
  proofUrl     String        @map("proof_url")
  status       FinanceStatus
  departmentId String        @map("department_id")
  approvedBy1  String?       @map("approved_by_1")
  approvedBy2  String?       @map("approved_by_2")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  department Department @relation(fields: [departmentId], references: [id])

  @@index([status])
  @@index([departmentId])
  @@map("finance_requests")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  actionUrl String           @map("action_url")
  readAt    DateTime?        @map("read_at")
  userId    String           @map("user_id")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("notifications")
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String      @map("entity_id")
  oldData   String?     @db.Text @map("old_data") // Using Text to store JSON as Prisma JSON varies by db
  newData   String?     @db.Text @map("new_data")
  userId    String      @map("user_id")
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}

model WebConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson String   @db.Text @map("value_json") // Using Text for JSON
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("web_configs")
}
